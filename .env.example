# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/ai_video_clipper

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# Auth
NEXTAUTH_SECRET=replace_with_secret
NEXTAUTH_URL=http://localhost:3000
DEV_USER_ID=00000000-0000-0000-0000-000000000001
DEV_USER_EMAIL=dev@example.com

# Storage
STORAGE_PROVIDER=supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=clips

# Alternative Storage
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=

# OpusClip Automation
OPUSCLIP_EMAIL=
OPUSCLIP_PASSWORD=
OPUSCLIP_BASE_URL=https://www.opus.pro
OPUSCLIP_APP_URL=https://www.opus.pro/clip
OPUSCLIP_LOGIN_URL=https://www.opus.pro/clip
OPUSCLIP_STORAGE_STATE_PATH=./playwright/.auth/opusclip.json
OPUSCLIP_ARTIFACTS_DIR=./artifacts/opusclip
OPUSCLIP_DOWNLOADS_DIR=./downloads/opusclip
OPUSCLIP_HEADLESS=true
OPUSCLIP_REQUIRE_SAVED_SESSION=false
OPUSCLIP_WORKER_CONCURRENCY=1
OPUSCLIP_WORKER_SIMULATION_MS=3000
OPUSCLIP_WORKER_SIMULATE_FAILURE=false
OPUSCLIP_PLACEHOLDER_WAIT_MS=1000
OPUSCLIP_ENABLE_REAL_SUBMIT=false
OPUSCLIP_ENABLE_REAL_WAIT=false
OPUSCLIP_ENABLE_REAL_LIST=false
OPUSCLIP_ENABLE_REAL_DOWNLOAD=false

# Composio
COMPOSIO_API_KEY=
COMPOSIO_TIKTOK_CONNECTED_ACCOUNT_ID=

# AI Caption
OPENAI_API_KEY=
