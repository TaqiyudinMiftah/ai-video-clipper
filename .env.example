# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/ai_video_clipper

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# Auth
NEXTAUTH_SECRET=replace_with_secret
NEXTAUTH_URL=http://localhost:3000
DEV_USER_ID=00000000-0000-0000-0000-000000000001
DEV_USER_EMAIL=dev@example.com

# Storage
STORAGE_PROVIDER=supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=clips
MAX_SOURCE_VIDEO_UPLOAD_MB=50

# Alternative Storage
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=

# OpusClip Automation
OPUSCLIP_EMAIL=
OPUSCLIP_PASSWORD=
OPUSCLIP_BASE_URL=https://clip.opus.pro
OPUSCLIP_APP_URL=https://clip.opus.pro/dashboard
OPUSCLIP_LOGIN_URL=https://clip.opus.pro/dashboard
OPUSCLIP_USE_PERSISTENT_CONTEXT=false
OPUSCLIP_USER_DATA_DIR=./playwright/.profiles/opusclip
OPUSCLIP_STORAGE_STATE_PATH=./playwright/.auth/opusclip.json
OPUSCLIP_ARTIFACTS_DIR=./artifacts/opusclip
OPUSCLIP_DOWNLOADS_DIR=./downloads/opusclip
OPUSCLIP_HEADLESS=true
OPUSCLIP_REQUIRE_SAVED_SESSION=false
OPUSCLIP_WORKER_CONCURRENCY=1
OPUSCLIP_WORKER_SIMULATION_MS=3000
OPUSCLIP_WORKER_SIMULATE_FAILURE=false
OPUSCLIP_MOCK_CREATE_CLIP=false
OPUSCLIP_PLACEHOLDER_WAIT_MS=1000
OPUSCLIP_SELECTOR_TIMEOUT_MS=5000
OPUSCLIP_PROCESSING_TIMEOUT_MS=2700000
OPUSCLIP_PROCESSING_POLL_MS=15000
OPUSCLIP_DOWNLOAD_TIMEOUT_MS=120000
OPUSCLIP_ENABLE_REAL_SUBMIT=false
OPUSCLIP_ENABLE_REAL_WAIT=false
OPUSCLIP_ENABLE_REAL_LIST=false
OPUSCLIP_ENABLE_REAL_DOWNLOAD=false
OPUSCLIP_UPLOAD_BUTTON_SELECTOR=
OPUSCLIP_FILE_INPUT_SELECTOR=
OPUSCLIP_URL_INPUT_SELECTOR=
OPUSCLIP_SUBMIT_BUTTON_SELECTOR=
OPUSCLIP_PROCESSING_COMPLETE_SELECTOR=
OPUSCLIP_GENERATED_CLIP_CARD_SELECTOR=
OPUSCLIP_CLIP_DOWNLOAD_BUTTON_SELECTOR=
OPUSCLIP_NEW_PROJECT_BUTTON_SELECTOR=

# OpusClip API (recommended for real clipping when your OpusClip plan has API access)
OPUSCLIP_USE_API=false
OPUSCLIP_API_BASE_URL=https://api.opus.pro/api
OPUSCLIP_API_KEY=
OPUSCLIP_ORG_ID=
OPUSCLIP_API_POLL_INTERVAL_MS=30000
OPUSCLIP_API_MAX_WAIT_MS=1800000
OPUSCLIP_API_CLIP_DURATION_SECONDS=90
OPUSCLIP_API_CURATION_MODEL=ClipBasic
OPUSCLIP_API_SOURCE_LANG=auto

# Composio
COMPOSIO_API_KEY=
COMPOSIO_TIKTOK_CONNECTED_ACCOUNT_ID=
COMPOSIO_TIKTOK_USER_ID=
COMPOSIO_TIKTOK_UPLOAD_ACTION=TIKTOK_UPLOAD_VIDEO
COMPOSIO_TOOLKIT_VERSION_TIKTOK=
COMPOSIO_TIKTOK_PUBLISH=false
COMPOSIO_TIKTOK_PRIVACY_LEVEL=SELF_ONLY
COMPOSIO_TIKTOK_DISABLE_COMMENT=false
COMPOSIO_TIKTOK_DISABLE_DUET=false
COMPOSIO_TIKTOK_DISABLE_STITCH=false
COMPOSIO_TIKTOK_SIGNED_URL_EXPIRES_SECONDS=3600
COMPOSIO_TIKTOK_EXTRA_ARGUMENTS=
UPLOAD_WORKER_CONCURRENCY=1

# AI Caption
OPENAI_API_KEY=
